# Sample environment variables for GreatMigration backend
# Copy to .env and adjust values as needed.

# Authentication method: "local" or "ldap"
AUTH_METHOD=local

# Shared settings
SESSION_SECRET=change_me
# Set to true in production so session cookies are marked Secure (HTTPS only)
SESSION_HTTPS_ONLY=true
MIST_TOKEN=change_me
MIST_BASE_URL=https://api.ac2.mist.com
# Optional Mist org and switch template settings
MIST_ORG_ID=
# Mist network template ID to pull port profiles from
SWITCH_TEMPLATE_ID=
# Optional help link shown in the UI
HELP_URL=https://github.com/ejstover/GreatMigration/blob/main/README.md
# Optional legacy VLAN range/list to preserve during cleanup (defaults to 500-599 when unset)
LEGACY_VLANS=500-599

# Optional compliance naming regex overrides
SWITCH_NAME_REGEX_PATTERN=
AP_NAME_REGEX_PATTERN=

# Comma-separated list of required Mist site variables for compliance checks. You can also
# provide default values using key=value pairs to enable 1 Click Fix for sites missing them.
MIST_SITE_VARIABLES=hubradiusserver=10.0.0.10,localradiusserver=10.0.0.20,siteDNS,hubDNSserver1=10.0.0.53,hubDNSserver2=10.0.0.54

# Comma-separated list of approved firmware versions per device type
STD_SW_VER=
STD_AP_VER=

# Optional device documentation requirements (default is 2 images each)
SW_NUM_IMG=2
AP_NUM_IMG=2

# Optional syslog server used for audit logging
SYSLOG_HOST=
# Syslog port (defaults to 514 if unset)
SYSLOG_PORT=514

# NetBox device type library (override URL or add local models)
NETBOX_DT_URL=https://api.github.com/repos/netbox-community/devicetype-library/contents/device-types
# Local JSON file with additional device types (optional)
NETBOX_LOCAL_DT=

# Local auth configuration
# Comma-separated list of username:password pairs
LOCAL_USERS=alice:REPLACE_WITH_STRONG_PASSWORD,bob:REPLACE_WITH_STRONG_PASSWORD
# Users allowed to push to Mist
LOCAL_PUSH_USERS=alice

# LDAP auth configuration (uncomment to use LDAP)
# AUTH_METHOD=ldap
# LDAP_SERVER_URL=ldaps://dc01.testdomain.local:636
# LDAP_SEARCH_BASE=DC=testdomain,DC=local
# LDAP_SEARCH_BASES=DC=testdomain,DC=local;DC=branch,DC=testdomain,DC=local  # semicolon/newline separated
# LDAP_BIND_TEMPLATE={username}@testdomain.local
# PUSH_GROUP_DN=CN=NetAuto-Push,OU=Groups,DC=testdomain,DC=local  # required for push access when set
# READONLY_GROUP_DN=CN=NetAuto-ReadOnly,OU=Groups,DC=testdomain,DC=local  # semicolon/newline separated
# LDAP_SERVICE_DN=CN=GreatMigration,CN=Users,DC=testdomain,DC=local
# LDAP_SERVICE_PASSWORD=change_me
